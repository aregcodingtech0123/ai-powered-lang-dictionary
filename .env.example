# Copy to backend/.env (when running the API from backend/) and/or frontend/.env.local.
# Never commit real secrets.

# --- Backend (Express / dictionary-api) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
PORT=3001
# Comma-separated origins, e.g. https://yourdomain.com
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# Rate limiting (global + per-route overrides; see README)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_TRANSLATE_GET_MAX=30
# RATE_LIMIT_REGENERATE_POST_MAX=5

# --- Frontend (Next.js) — NEXT_PUBLIC_* is exposed to the browser ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_ADMIN_EMAIL=
