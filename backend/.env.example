GEMINI_API_KEY=your_api_key_here
# Optional model id (default: gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash
PORT=3001
# Bind address (use 0.0.0.0 on Render/Docker; default is 0.0.0.0)
# HOST=0.0.0.0

# Production frontend URL (Vercel) — required on Render for browser CORS
# FRONTEND_URL=https://your-app.vercel.app

# Optional: extra comma-separated origins (Docker, preview deploys, custom domains)
# CORS_ORIGIN=https://vocabeacon.com

# Rate limiting (see README — "Rate limiting")
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_TRANSLATE_GET_MAX=30
# RATE_LIMIT_REGENERATE_POST_MAX=5

# Admin mailbox used by frontend contact form
ADMIN_EMAIL=admin@example.com
