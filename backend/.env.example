GEMINI_API_KEY=your_api_key_here
# Optional model id (default: gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash
PORT=3001
# Optional: allow your Next.js origin
# CORS_ORIGIN=http://localhost:3000

# Rate limiting (see README — "Rate limiting")
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_TRANSLATE_GET_MAX=30
# RATE_LIMIT_REGENERATE_POST_MAX=5

# Admin mailbox used by frontend contact form
ADMIN_EMAIL=admin@example.com
